N = int(input())
data = []
for i in range(N):
    name = input()
    score = float(input())
    data.append([score, name])

data.sort()
lowest = data[0][0]
start = False
for score, name in data:
    if score != lowest and not start:
        start = True
        lowest = score
    if score != lowest and start:
        break
    if start:
        print(name)
