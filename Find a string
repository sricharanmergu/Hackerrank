def count_substring(string, sub_string):
    count = 0
    l = len(string)
    ls = len(sub_string)
    for x in range(l - ls +1):
        if string[x : (x + ls)] == sub_string:
            count += 1
    return count

if __name__ == '__main__':
    string = input().strip()
    sub_string = input().strip()
    
    count = count_substring(string, sub_string)
    print(count)
